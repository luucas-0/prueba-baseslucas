{
  "info": {
    "_postman_id": "megastore-api-collection",
    "name": "MegaStore API",
    "description": "Complete REST API collection for MegaStore database management system. Includes CRUD operations, analytics, and data management endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"]
            },
            "description": "Retrieve all products from the database"
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "{{product_id}}"]
            },
            "description": "Retrieve a specific product by SKU/ID"
          },
          "response": []
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"SKU-NEW-001\",\n  \"name\": \"New Product\",\n  \"unit_price\": 99.99,\n  \"category_id\": 1,\n  \"supplier_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"]
            },
            "description": "Create a new product with fields sku, name, unit_price, category_id, supplier_id"
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product Name\",\n  \"unit_price\": 149.99\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "{{product_id}}"]
            },
            "description": "Update fields (name, unit_price, category_id, supplier_id) of an existing product"
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "{{product_id}}"]
            },
            "description": "Delete a product (creates audit log entry)"
          },
          "response": []
        },
        {
          "name": "Download CSV",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products/csv",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "csv"]
            },
            "description": "Download the original migration CSV file"
          },
          "response": []
        },
        {
          "name": "Get Product Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products/audit/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "audit", "{{product_id}}"]
            },
            "description": "Retrieve audit logs for a specific product (deletions, modifications)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Supplier Analysis",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/analytics/suppliers",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "suppliers"]
            },
            "description": "Get detailed supplier performance analysis including products, sales volume, and revenue"
          },
          "response": []
        },
        {
          "name": "Customer Purchase History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/analytics/customers/{{customer_id}}/history",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "customers", "{{customer_id}}", "history"]
            },
            "description": "Retrieve complete purchase history for a specific customer including total spent and order details"
          },
          "response": []
        },
        {
          "name": "Top Products by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/analytics/products/top-by-category/{{category_name}}",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "products", "top-by-category", "{{category_name}}"]
            },
            "description": "Get top-selling products filtered by category with revenue and quantity metrics"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "product_id",
      "value": "SKU-001",
      "type": "string",
      "description": "Product SKU identifier"
    },
    {
      "key": "customer_id",
      "value": "1",
      "type": "string",
      "description": "Customer ID for analytics queries"
    },
    {
      "key": "category_name",
      "value": "Electronics",
      "type": "string",
      "description": "Product category name"
    }
  ]
}
